# gcloud builds submit / gcloud run deploy --source follow .gitignore by
# default when no .gcloudignore is present — which would silently exclude
# data/*.csv and artifacts/* from the uploaded source tarball (they're
# gitignored for the repo, but the deploy images need them). This file
# overrides that so the actual generated data/model artifacts get uploaded.
.git
.venv
venv
__pycache__
*.pyc
*.egg-info
.pytest_cache
tests/
implementation-notes.md
.torch_cache
feature_repo/registry.db
feature_repo/online_store.db
feature_repo/data/*.parquet
