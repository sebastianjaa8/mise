# Gateway is the lightest of the three: no ML libs at all, no data/ or
# artifacts/ — it only ever proxies JSON between the other two services.
FROM python:3.12-slim
WORKDIR /app

COPY deploy/requirements-gateway.txt ./requirements.txt
RUN pip install --no-cache-dir -r requirements.txt

COPY pyproject.toml ./
COPY src/ ./src/
RUN pip install --no-cache-dir -e . --no-deps

ENV PORT=8080
EXPOSE 8080
CMD exec uvicorn services.gateway:app --host 0.0.0.0 --port ${PORT}
